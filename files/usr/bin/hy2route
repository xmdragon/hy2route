#!/bin/sh
set -eu
GEN=/usr/libexec/hy2route/generate.uc
PROG=/usr/bin/hy2route-core
RUNDIR=/tmp/hy2route
umask 077
usage() { echo 'usage: hy2route <check|status|test|reload>' >&2; exit 2; }
case "${1:-}" in
	check)
		mkdir -p -m 700 "$RUNDIR"
		"$GEN" core > "$RUNDIR/core.check.json"
		chmod 600 "$RUNDIR/core.check.json"
		"$PROG" check --config "$RUNDIR/core.check.json"
		"$GEN" nft > "$RUNDIR/nft.check.conf"
		nft -c -f "$RUNDIR/nft.check.conf"
		echo 'hy2route configuration is valid'
		;;
	status)
		"$PROG" status --socket /var/run/hy2route-core.sock
		;;
	test) "$PROG" check --config "$RUNDIR/core.json" ;;
	reload) /etc/init.d/hy2route reload ;;
	*) usage ;;
esac
