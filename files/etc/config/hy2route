config main 'main'
	option enabled '0'
	option lan_interface 'br-lan'
	option transparent_port '12345'
	option test_socks_port '10780'
	option dns_port '1053'
	option smart_dns '1'
	option smart_dns_port '65353'
	option remote_dns '8.8.8.8'
	option bootstrap_dns '192.168.1.1'
	option fwmark '102'
	option route_table '166'
	option log_level 'warning'
	option udp_policy 'proxy'
	option block_ipv6 '1'

config hy2 'relay'
	option server 'REPLACE_WITH_RELAY_IP_OR_DOMAIN'
	option port '443'
	option auth 'REPLACE_WITH_HY2_PASSWORD'
	option sni 'REPLACE_WITH_RELAY_SNI'
	option allow_insecure '0'
	option pinned_cert_sha256 ''
	option congestion 'bbr'
	option bbr_profile 'standard'
	option udp_idle_timeout '60'
	option max_idle_timeout '60'
	option keep_alive_period '0'
	option disable_mtu_discovery '0'

config vless 'tcp_relay'
	option enabled '0'
	option server 'REPLACE_WITH_RELAY_IP_OR_DOMAIN'
	option port '443'
	option id ''
	option server_name 'REPLACE_WITH_REALITY_SERVER_NAME'
	option reality_password ''
	option short_id ''
	option fingerprint 'chrome'
	option flow 'xtls-rprx-vision'
	option spider_x ''

config landing 'landing'
	option type 'socks'
	option server 'REPLACE_WITH_LANDING_IP_OR_DOMAIN'
	option port '443'
	option username 'REPLACE_WITH_USERNAME'
	option password 'REPLACE_WITH_PASSWORD'

